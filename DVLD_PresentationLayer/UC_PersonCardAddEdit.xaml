<UserControl x:Class="DVLD_PresentationLayer.UC_PersonCardAddEdit"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DVLD_PresentationLayer"
             mc:Ignorable="d" Height="488" Width="953">
    <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1.5" CornerRadius="12" Margin="5">
        <Grid Margin="15,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170" />
                <!-- عمود الصورة الشخصية والتحكم بها -->
                <ColumnDefinition Width="*" />
                <!-- عمود الحقول والبيانات -->
            </Grid.ColumnDefinitions>

            <!-- ================= العمود الأول: الصورة والـ ID والأزرار ================= -->
            <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center">

                <!-- 🌟 الـ Person ID معروض بشكل أنيق ومنسق مباشرة فوق الدائرة 🌟 -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                    <TextBlock Text="ID: " 
                               FontSize="12" 
                               Foreground="#94A3B8" 
                               FontWeight="Bold" 
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="lblPersonID" 
                               Text="????" 
                               FontSize="14" 
                               Foreground="#3B82F6" 
                               FontWeight="ExtraBold" 
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- ================= الدائرة الخاصة بالصورة الشخصية ================= -->
                <Border Width="110" Height="110" CornerRadius="55" BorderBrush="#CBD5E0" BorderThickness="2" HorizontalAlignment="Center">
                    <Grid>
                        <!-- الأيقونة الافتراضية (تظهر تلقائياً فقط لو مفيش صورة) -->
                        <TextBlock x:Name="txtGenderIcon" 
                                   Text="👤" 
                                   FontSize="54" 
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center" 
                                   Foreground="#A0AEC0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <!-- إذا كان مصدر الصورة فارغاً (Null)، أظهر الأيقونة الافتراضية -->
                                        <DataTrigger Binding="{Binding ElementName=imgPerson, Path=ImageSource}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- الصورة الفعلية المعروضة -->
                        <Border CornerRadius="55">
                            <Border.Background>
                                <ImageBrush x:Name="imgPerson" Stretch="UniformToFill" />
                            </Border.Background>
                        </Border>
                    </Grid>
                </Border>

                <!-- ================= أزرار التحكم (تنسيق أفقي) ================= -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">

                    <!-- زر اختيار صورة (ثابت دائماً) -->
                    <Button x:Name="btnSetImage" Content="📁 Set" Width="60" Height="25" FontSize="11" Background="#E2E8F0" Foreground="#4A5568" BorderThickness="0" Cursor="Hand" Click="btnSetImage_Click_1">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <!-- زر حذف الصورة (يظهر ويختفي ديناميكياً بحسب وجود صورة) -->
                    <Button x:Name="btnRemoveImage" Content="❌ Remove" Width="75" Height="25" FontSize="11" Background="#FEE2E2" Foreground="#EF4444" BorderThickness="0" Cursor="Hand" Margin="5,0,0,0" Click="btnRemoveImage_Click_1">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                        <Button.Style>
                            <Style TargetType="Button">
                                <!-- الحالة الافتراضية للزر: ظاهر -->
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <!-- شرط ذكي: لو الـ ImageSource بتاع الـ imgPerson قيمته Null، اخفي الزرار تماماً -->
                                    <DataTrigger Binding="{Binding ElementName=imgPerson, Path=ImageSource}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                </StackPanel>
            </StackPanel>

            <!-- ================= الجانب الأيمن: حقول البيانات بالتفصيل ================= -->
            <Grid Grid.Column="1" Margin="15,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Row 0 -->
                    <RowDefinition Height="Auto"/>
                    <!-- Row 1 -->
                    <RowDefinition Height="Auto"/>
                    <!-- Row 2 -->
                    <RowDefinition Height="Auto"/>
                    <!-- Row 3 -->
                    <RowDefinition Height="Auto"/>
                    <!-- Row 4 -->
                    <RowDefinition Height="Auto"/>
                    <!-- Row 5 -->
                    <RowDefinition Height="Auto"/>
                    <!-- Row 6: Address -->
                    <RowDefinition Height="Auto"/>
                    <!-- Row 7: Buttons -->
                </Grid.RowDefinitions>

                <!-- الصف الأول: الاسم الأول والاسم الثاني -->
                <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,3">
                    <TextBlock Text="👤 First Name" FontSize="10" Foreground="#A0AEC0" FontWeight="Bold" Margin="0,0,0,1"/>
                    <TextBox x:Name="txtFirstName" PreviewTextInput="txtNameFields_PreviewTextInput" TextChanged="txtFirstName_TextChanged" Height="32" VerticalContentAlignment="Center" Padding="5,0"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="2" Margin="5,3,0,3">
                    <TextBlock Text="👤 Second Name" FontSize="10" Foreground="#A0AEC0" FontWeight="Bold" Margin="0,0,0,1"/>
                    <TextBox x:Name="txtSecondName" PreviewTextInput="txtNameFields_PreviewTextInput" TextChanged="txtSecondName_TextChanged" Height="32" VerticalContentAlignment="Center" Padding="5,0"/>
                </StackPanel>

                <!-- الصف الثاني: الاسم الثالث والاسم الأخير -->
                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,3">
                    <TextBlock Text="👤 Third Name" FontSize="10" Foreground="#A0AEC0" FontWeight="Bold" Margin="0,0,0,1"/>
                    <TextBox x:Name="txtThirdName" PreviewTextInput="txtNameFields_PreviewTextInput" TextChanged="txtThirdName_TextChanged" Height="32" VerticalContentAlignment="Center" Padding="5,0"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2" Margin="5,3,0,3">
                    <TextBlock Text="👤 Last Name" FontSize="10" Foreground="#A0AEC0" FontWeight="Bold" Margin="0,0,0,1"/>
                    <TextBox x:Name="txtLastName" PreviewTextInput="txtNameFields_PreviewTextInput" TextChanged="txtLastName_TextChanged" Height="32" VerticalContentAlignment="Center" Padding="5,0"/>
                </StackPanel>

                <!-- الصف الثالث: الرقم الوطني وتاريخ الميلاد -->
                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,3">
                    <TextBlock Text="💳 National No" FontSize="10" Foreground="#A0AEC0" FontWeight="Bold" Margin="0,0,0,1"/>
                    <TextBox x:Name="txtNationalNo" LostFocus="txtNationalNo_LostFocus" Height="32" VerticalContentAlignment="Center" Padding="5,0"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="2" Margin="5,3,0,3">
                    <TextBlock Text="📅 Date Of Birth" FontSize="10" Foreground="#A0AEC0" FontWeight="Bold" Margin="0,0,0,1"/>
                    <DatePicker x:Name="dtpDateOfBirth" Height="32" VerticalContentAlignment="Center"/>
                </StackPanel>

                <!-- الصف الرابع: الهاتف الأول والهاتف الثاني -->
                <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,3">
                    <TextBlock Text="📞 Phone 1"  FontSize="10" Foreground="#A0AEC0" FontWeight="Bold" Margin="0,0,0,1"/>
                    <TextBox x:Name="txtPhone1" DataObject.Pasting="txtPhone_Pasting"  PreviewTextInput="txtPhone_PreviewTextInput" Height="32" VerticalContentAlignment="Center" Padding="5,0"/>
                </StackPanel>

                <StackPanel Grid.Row="3" Grid.Column="2" Grid.ColumnSpan="2" Margin="5,3,0,3">
                    <TextBlock Text="📱 Phone 2" FontSize="10" Foreground="#A0AEC0" FontWeight="Bold" Margin="0,0,0,1"/>
                    <TextBox x:Name="txtPhone2" DataObject.Pasting="txtPhone_Pasting" PreviewTextInput="txtPhone_PreviewTextInput" Height="32" VerticalContentAlignment="Center" Padding="5,0"/>
                </StackPanel>

                <!-- الصف الخامس: اختيار الجنس (Gender) والبلد (Country) -->
                <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,5">
                    <TextBlock Text="🚻 Gender" FontSize="10" Foreground="#A0AEC0" FontWeight="Bold" Margin="0,0,0,3"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Height="32">
                        <RadioButton x:Name="rbMale" Content="🧔 Male" IsChecked="True" FontSize="11" FontWeight="SemiBold" Foreground="#2D3748" Cursor="Hand" Margin="0,0,15,0" Checked="rbGender_Checked"/>
                        <RadioButton x:Name="rbFemale" Content="👩 Female" FontSize="11" FontWeight="SemiBold" Foreground="#2D3748" Cursor="Hand" Checked="rbGender_Checked"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="4" Grid.Column="2" Grid.ColumnSpan="2" Margin="5,3,0,3">
                    <TextBlock Text="🌐 Country" FontSize="10" Foreground="#A0AEC0" FontWeight="Bold" Margin="0,0,0,1"/>
                    <ComboBox x:Name="cbCountries" Height="32" VerticalContentAlignment="Center"/>
                </StackPanel>

                <!-- الصف السادس: البريد الإلكتروني -->
                <StackPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="4" Margin="0,3">
                    <TextBlock Text="✉️ Email Address" FontSize="10" Foreground="#A0AEC0" FontWeight="Bold" Margin="0,0,0,1"/>
                    <TextBox x:Name="txtEmail" TextChanged="txtEmail_TextChanged" BorderThickness="1" BorderBrush="DarkGray" ToolTip="Enter your Gmail address" Height="32" VerticalContentAlignment="Center" Padding="5,0"/>
                </StackPanel>

                <!-- الصف السابع: العنوان الكامل -->
                <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="4" Margin="0,3,0,0">
                    <TextBlock Text="📍 Address" FontSize="10" Foreground="#A0AEC0" FontWeight="Bold" Margin="0,0,0,1"/>
                    <TextBox x:Name="txtAddress" PreviewTextInput="txtAddress_PreviewTextInput" TextChanged="txtAddress_TextChanged" Height="50" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top" Padding="5"/>
                </StackPanel>

                <!-- الـ StackPanel الخاص بالأزرار -->
                <StackPanel Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="4" 
                            Orientation="Horizontal" 
                            HorizontalAlignment="Right" 
                            Margin="0,20,0,0">
                    <Button x:Name="btnSave" Content="💾 Save" Width="100" Height="35" Click="btnSave_Click"  />
                    <Button x:Name="btnClose" Content="❌ Cancel" Width="100" Height="35" Click="btnClose_Click" Margin="10,0,0,0"  />
                </StackPanel>

            </Grid>
        </Grid>
    </Border>
</UserControl>