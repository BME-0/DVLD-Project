<UserControl x:Class="DVLD_PresentationLayer.UC_PersonCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DVLD_PresentationLayer"
             mc:Ignorable="d" 
             d:DesignHeight="270" d:DesignWidth="850"
             HorizontalAlignment="Stretch" VerticalAlignment="Stretch">

    <!-- تم تصحيح الـ Margin السلبي ليكون متناسقاً من كل الجهات -->
    <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1.5" CornerRadius="12" Margin="5">
        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <!-- العمود الأيسر للصورة والـ ID بأبعاد مرنة ومحددة بحد أقصى وأدنى -->
                <ColumnDefinition Width="Auto" MinWidth="150" MaxWidth="200" />
                <!-- عمود البيانات التفصيلية يأخذ باقي مساحة الكارت بالتساوي -->
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ================= الجانب الأيسر: الهوية والصورة الشخصية ================= -->
            <Border Grid.Column="0" Background="#EDF2F7" CornerRadius="11" Padding="10" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- ID الرقم التعريفي -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,5">
                        <TextBlock Text="Person ID:" FontSize="11" Foreground="#718096" FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock x:Name="lblPersonID" Text="N/A" FontSize="14" FontWeight="Black" Foreground="#2B6CB0" Margin="4,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- الصورة الشخصية بحواف دائرية -->
                    <Border Grid.Row="1" Width="95" Height="95" CornerRadius="47.5" BorderBrush="#CBD5E0" BorderThickness="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Grid>
                            <!-- الرمز التعبيري الخلفي -->
                            <TextBlock x:Name="txtGenderIcon" 
                                       Text="👤" 
                                       FontSize="48" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center" 
                                       Foreground="#A0AEC0"/>

                            <!-- طبقة الصورة الفوقية -->
                            <Border CornerRadius="47.5">
                                <Border.Background>
                                    <ImageBrush x:Name="imgPerson" Stretch="UniformToFill"/>
                                </Border.Background>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- الدولة والجنسية -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0">
                        <TextBlock Text="🌐" FontSize="11" Margin="0,0,3,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="lblCountryName" Text="N/A" FontSize="11" FontWeight="Bold" Foreground="#4A5568" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ================= الجانب الأيمن: حقول البيانات بالتفصيل ================= -->
            <Grid Grid.Column="1" Margin="5,0,5,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- الصف الأول: الاسم الأول والاسم الثاني -->
                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,2">
                    <TextBlock Text="👤 First Name" FontSize="10" Foreground="#A0AEC0" FontWeight="Bold"/>
                    <TextBlock x:Name="lblFirstName" Text="N/A" FontSize="12" Foreground="#2D3748" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="1" Margin="5,2,0,2">
                    <TextBlock Text="👤 Second Name" FontSize="10" Foreground="#A0AEC0" FontWeight="Bold"/>
                    <TextBlock x:Name="lblSecondName" Text="N/A" FontSize="12" Foreground="#2D3748" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <!-- الصف الثاني: الاسم الثالث والاسم الأخير -->
                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,2">
                    <TextBlock Text="👤 Third Name" FontSize="10" Foreground="#A0AEC0" FontWeight="Bold"/>
                    <TextBlock x:Name="lblThirdName" Text="—" FontSize="12" Foreground="#2D3748" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="1" Margin="5,2,0,2">
                    <TextBlock Text="👤 Last Name" FontSize="10" Foreground="#A0AEC0" FontWeight="Bold"/>
                    <TextBlock x:Name="lblLastName" Text="N/A" FontSize="12" Foreground="#2D3748" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <!-- الصف الثالث: الرقم الوطني وتاريخ الميلاد -->
                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,2">
                    <TextBlock Text="💳 National No" FontSize="10" Foreground="#A0AEC0" FontWeight="Bold"/>
                    <TextBlock x:Name="lblNationalNo" Text="N/A" FontSize="12" Foreground="#2D3748" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="1" Margin="5,2,0,2">
                    <TextBlock Text="📅 Date Of Birth / Age" FontSize="10" Foreground="#A0AEC0" FontWeight="Bold"/>
                    <TextBlock x:Name="lblDateOfBirthAndAge" Text="N/A" FontSize="12" Foreground="#2D3748" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <!-- الصف الرابع: الهاتف الأول والهاتف الثاني -->
                <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,2">
                    <TextBlock Text="📞 Phone 1" FontSize="10" Foreground="#A0AEC0" FontWeight="Bold"/>
                    <TextBlock x:Name="lblPhone1" Text="N/A" FontSize="12" Foreground="#2D3748" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <StackPanel Grid.Row="3" Grid.Column="1" Margin="5,2,0,2">
                    <TextBlock Text="📱 Phone 2" FontSize="10" Foreground="#A0AEC0" FontWeight="Bold"/>
                    <TextBlock x:Name="lblPhone2" Text="—" FontSize="12" Foreground="#718096" FontWeight="Medium" TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <!-- الصف الخامس: البريد الإلكتروني -->
                <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,2">
                    <TextBlock Text="✉️ Email Address" FontSize="10" Foreground="#A0AEC0" FontWeight="Bold"/>
                    <TextBlock x:Name="lblEmail" Text="—" FontSize="12" Foreground="#2D3748" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <!-- الصف السادس: العنوان الكامل -->
                <StackPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,2">
                    <TextBlock Text="📍 Address" FontSize="10" Foreground="#A0AEC0" FontWeight="Bold"/>
                    <TextBlock x:Name="lblAddress" Text="N/A" FontSize="12" Foreground="#4A5568" TextWrapping="Wrap" TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <!-- الصف السابع: الجنس -->
                <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,2">
                    <TextBlock Text="🚻 Gender" FontSize="10" Foreground="#A0AEC0" FontWeight="Bold"/>
                    <TextBlock x:Name="lblGender" Text="N/A" FontSize="12" Foreground="#2D3748" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>